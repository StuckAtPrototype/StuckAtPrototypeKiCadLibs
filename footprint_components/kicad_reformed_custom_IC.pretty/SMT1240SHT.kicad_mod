(module "SMT1240SHT" (layer F.Cu)
  (descr "12.20mm x 12.00mm x 2.8mm")
  (tags "Loudspeaker or Buzzer")
  (attr smd)
  (fp_text reference LS** (at 0.000 -0) (layer F.SilkS)
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_text user %R (at 0.000 -0) (layer F.Fab)
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_text value "SMT1240SHT" (at 0.000 -0) (layer F.SilkS) hide
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_line (start -6 -6) (end 6 -6) (layer F.Fab) (width 0.1))
  (fp_line (start 6 -6) (end 6 6) (layer F.Fab) (width 0.1))
  (fp_line (start 6 6) (end -6 6) (layer F.Fab) (width 0.1))
  (fp_line (start -6 6) (end -6 -6) (layer F.Fab) (width 0.1))
  (fp_line (start -7 -7.2) (end 7 -7.2) (layer F.CrtYd) (width 0.1))
  (fp_line (start 7 -7.2) (end 7 7.2) (layer F.CrtYd) (width 0.1))
  (fp_line (start 7 7.2) (end -7 7.2) (layer F.CrtYd) (width 0.1))
  (fp_line (start -7 7.2) (end -7 -7.2) (layer F.CrtYd) (width 0.1))
  (fp_line (start 2.4 -6) (end 6 -6) (layer F.SilkS) (width 0.2))
  (fp_line (start 6 -6) (end 6 6) (layer F.SilkS) (width 0.2))
  (fp_line (start 6 6) (end 2.4 6) (layer F.SilkS) (width 0.2))
  (fp_line (start -2.4 6) (end -6 6) (layer F.SilkS) (width 0.2))
  (fp_line (start -6 6) (end -6 -6) (layer F.SilkS) (width 0.2))
  (fp_line (start -6 -6) (end -2.4 -6) (layer F.SilkS) (width 0.2))
  (fp_line (start 0 -6.6) (end 0 -6.6) (layer F.SilkS) (width 0.1))
  (fp_line (start 0 -6.7) (end 0 -6.7) (layer F.SilkS) (width 0.1))
  (fp_arc (start 0 -6.65) (end 0.000 -6.6) (angle -180) (layer F.SilkS) (width 0.1))
  (fp_arc (start 0 -6.65) (end 0.000 -6.7) (angle -180) (layer F.SilkS) (width 0.1))
  (pad 1 smd rect (at 0.000 -5.475 90) (size 1.450 4.000) (layers F.Cu F.Paste F.Mask))
  (pad 2 smd rect (at 0.000 5.475 90) (size 1.450 4.000) (layers F.Cu F.Paste F.Mask))
  (model SMT-1240-S-HT.stp
    (at (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0))
  )
)
